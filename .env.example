# Database — Railway PostgreSQL URL ya local
DATABASE_URL=postgresql://user:password@host:5432/araschool

# Server
PORT=8080
NODE_ENV=production

# Sessions
SESSION_SECRET=your-super-secret-key-change-this

# Twilio (optional — SMS feature ke liye)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Frontend URL (CORS ke liye)
FRONTEND_URL=https://your-frontend-domain.com
